{
  "name": "fastify-server",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "start": "tsx --env-file=.env server.ts",
    "dev": "tsx watch --env-file=.env server.ts",
    "db:generate": "node --env-file=.env ./node_modules/.bin/drizzle-kit generate",
    "db:push": "node --env-file=.env ./node_modules/.bin/drizzle-kit push",
    "db:pull": "node --env-file=.env ./node_modules/.bin/drizzle-kit pull",
    "db:migrate": "node --env-file=.env db/migrate.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
